# Optional fallback media URL prefix. Usually not needed with UploadThing because
# scripts/media:upload writes absolute URLs into archive-manifest.json.
VITE_MEDIA_BASE_URL=

# Used by scripts/upload-uploadthing-media.mjs. Keep this local; do not expose it
# in GitHub Pages or frontend code.
UPLOADTHING_TOKEN=
UPLOADTHING_APP_ID=
PB_DATA_DIR=../park-map-demo/pocketbase/pb_data
